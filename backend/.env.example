# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Redis (use redis/redis-stack-server for vector rubric search)
REDIS_URL=redis://localhost:6379
# RUBRIC_EMBED_MODEL=BAAI/bge-small-en-v1.5
# SEMANTIC_UNCHANGED_THRESHOLD=0.97

# Browserbase
BROWSERBASE_API_KEY=bb_live_...
BROWSERBASE_PROJECT_ID=...

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=...

# Sentry (optional — strongly recommended for hackathon demo)
SENTRY_DSN=https://...@sentry.io/...
# SENTRY_RELEASE=scaffold-backend@1.0.0
# SENTRY_TRACES_SAMPLE_RATE=1.0

# Arize Phoenix
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006/v1/traces
# PHOENIX_API_KEY=...  # required for Arize cloud

# App
ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.vercel.app
ENVIRONMENT=development

# Google OAuth (Google Docs live tracker)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
FRONTEND_URL=http://localhost:3000
